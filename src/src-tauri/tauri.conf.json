{
  "productName": "LimbusManager",
  "identifier": "com.limbus.manager",
  "build": {
    "beforeBuildCommand": "npm run build",
    "distDir": "../dist"
  },
  "app": {
    "security": {
      "capabilities": [
        "fs:allow-writeFile",
        "fs:allow-mkdir",
        "dialog:allow-open"
      ]
    }
  },
  "bundle": {
    "active": true
  }
}
